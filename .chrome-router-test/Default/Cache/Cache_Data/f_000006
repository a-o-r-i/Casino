  <div
    class="pointer-events-none fixed inset-0 z-40 flex items-center justify-center px-4 opacity-0"
    data-create-modal
  >
    <div
      class="absolute inset-0 bg-black/0"
      data-create-modal-overlay
      data-close-create-modal
    ></div>

    <section
      class="relative z-10 w-full max-w-[420px] translate-y-6 scale-[0.96] rounded-3xl border border-white/8 bg-[#0b0c10] p-6 opacity-0 shadow-[0_28px_80px_rgba(0,0,0,0.48)]"
      data-create-modal-panel
    >
      <div>
        <h2 class="mt-2 text-2xl font-semibold tracking-[-0.05em] text-white">New coinflip</h2>
      </div>

      <form
        class="mt-6 space-y-6"
        method="post"
        action="/games/coinflip/sessions"
        data-balance-cents="6000"
        data-create-session-form
      >
        <div class="space-y-2">
          <label class="block text-sm font-medium text-white/80" for="bet_amount">
            Bet amount
          </label>
          <div class="flex items-stretch gap-2">
            <input
              class="h-12 min-w-0 flex-1 rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-base text-white outline-none transition placeholder:text-white/25 focus:border-white/20"
              id="bet_amount"
              max="60.00"
              min="1"
              name="bet_amount"
              placeholder="10"
              step="0.01"
              type="number"
              data-bet-amount-input
            >
            <button
              class="inline-flex h-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm font-medium text-white/80 transition hover:bg-white/[0.06]"
              data-adjust-bet="half"
              type="button"
            >
              /2
            </button>
            <button
              class="inline-flex h-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm font-medium text-white/80 transition hover:bg-white/[0.06]"
              data-adjust-bet="double"
              type="button"
            >
              x2
            </button>
          </div>
          <div class="flex items-center justify-between gap-3">
            <button
              class="inline-flex h-10 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm font-medium text-white/80 transition hover:bg-white/[0.06]"
              data-use-previous-bet
              type="button"
            >
              Same as previous
            </button>
            <p class="text-xs text-white/40">Max $60</p>
          </div>
        </div>

        <div class="space-y-3">
          <p class="text-sm font-medium text-white/80">Choose your side</p>
          <div class="grid grid-cols-2 gap-3">
            <label class="block cursor-pointer">
              <input class="peer sr-only" name="choice" type="radio" value="Heads">
              <span class="flex h-14 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm font-medium text-white/72 transition hover:bg-white/[0.05] peer-checked:border-white/0 peer-checked:bg-white peer-checked:text-black peer-checked:hover:bg-white">
                Heads
              </span>
            </label>
            <label class="block cursor-pointer">
              <input class="peer sr-only" name="choice" type="radio" value="Tails">
              <span class="flex h-14 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] px-4 text-sm font-medium text-white/72 transition hover:bg-white/[0.05] peer-checked:border-white/0 peer-checked:bg-white peer-checked:text-black peer-checked:hover:bg-white">
                Tails
              </span>
            </label>
          </div>
        </div>

        <button
          class="inline-flex h-12 w-full items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-5 text-sm font-medium text-white transition hover:bg-white/10"
          data-create-session-submit
          type="submit"
        >
          Create session
        </button>
      </form>
    </section>
